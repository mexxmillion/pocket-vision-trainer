# Copy to .env and fill in your keys

# USDA FoodData Central (free, get key at https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=DEMO_KEY

# Nutritionix (free tier, 500 calls/day, https://developer.nutritionix.com/)
NUTRITIONIX_APP_ID=
NUTRITIONIX_API_KEY=

# Flickr (free, https://www.flickr.com/services/api/misc.api_keys.html)
FLICKR_API_KEY=

# Unsplash (free, https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=

# Weights & Biases (optional, for training logging)
WANDB_API_KEY=
WANDB_PROJECT=pocket-vision-train

# HuggingFace (for model upload)
HF_TOKEN=
